# Server Configuration
PORT=5000

# Email SMTP Settings (e.g. for Gmail, Outlook, or SMTP service like Mailtrap/Sendgrid)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
# EMAIL_PORT=465  # Use port 465 for SSL, 587 for TLS

# Your email login credentials
# For Gmail, it is highly recommended to use a 16-character App Password (not your primary password)
# Learn more: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# The email address that should receive the message
# If left empty, it will default to EMAIL_USER
RECEIVER_EMAIL=dedeepyachilakala@gmail.com
